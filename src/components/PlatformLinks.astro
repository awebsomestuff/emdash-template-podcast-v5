---
interface Props {
	spotify?: string | null;
	apple?: string | null;
	youtube?: string | null;
	rss?: string | null;
	size?: "sm" | "md" | "lg";
}

const { spotify, apple, youtube, rss = "/rss.xml", size = "md" } = Astro.props;
---
<div class={`platform-links${size === "lg" ? " lg" : ""}`}>
	{spotify && (
